rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // ADMIN check: your Auth UID must exist as a document in /admins.
    // To make yourself an admin: Firebase Console → Firestore → create a
    // collection "admins" → add a document whose ID = your Auth UID.
    // Admins can then change any user's plan (the dropdown in the dashboard),
    // and delete users. The payment function (Firebase Admin SDK) bypasses
    // all of these rules anyway.
    // ---------------------------------------------------------------------
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // true unless a normal client is trying to set its OWN plan to 'premium'
    function notSelfUpgrading() {
      return request.resource.data.plan == resource.data.plan
             || request.resource.data.plan != 'premium';
    }

    match /admins/{uid} {
      allow read: if request.auth != null;  // app can check "am I an admin?"
      allow write: if false;                // only the Firebase console adds admins
    }

    match /users/{userId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.plan != 'premium';

      allow update: if isAdmin()                                          // admins: change anything (incl. plan)
        || (request.auth != null && request.auth.uid == userId && notSelfUpgrading())
        || (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['referralCount', 'referralActive', 'premiumUntil', 'referredBy', 'referralProcessed']));

      allow delete: if isAdmin();

      // Activity subcollections belong to the owner
      match /{sub=**} {
        allow read, write: if request.auth != null;
      }
    }

    match /passwordResetRequests/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
